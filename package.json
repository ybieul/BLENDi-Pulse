{
  "name": "blendi-pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "mobile": "pnpm --filter @blendi/mobile start",
    "api": "pnpm --filter @blendi/api dev",
    "dev": "pnpm --parallel --filter @blendi/mobile --filter @blendi/api start",
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "pnpm --recursive lint",
    "clean": "pnpm --recursive exec rm -rf node_modules dist .expo"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}

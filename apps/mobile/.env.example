# apps/mobile/.env.example
# Copie este arquivo para .env e preencha os valores para o seu ambiente.
# Variáveis com prefixo EXPO_PUBLIC_ são expostas ao bundle — nunca coloque secrets aqui.

# URL base da API — sem barra final
# Desenvolvimento local (iOS Simulator): http://localhost:3000
# Desenvolvimento local (Android Emulator): http://10.0.2.2:3000
# Desenvolvimento local (dispositivo físico): http://<IP_DA_SUA_MAQUINA>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000


{
  "expo": {
    "name": "BLENDi Pulse",
    "slug": "blendi-pulse",
    "scheme": "blendipulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#2b1429",
    "primaryColor": "#9a4893",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2b1429"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "BLENDi Pulse usa a câmera para o Pantry Scanner.",
        "NSPhotoLibraryUsageDescription": "BLENDi Pulse acessa a galeria para fotos de receitas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2b1429"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2b1429",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "PENDING_EAS_PROJECT_ID"
      }
    }
  }
}

# ─── BLENDi Pulse API — variáveis de ambiente ─────────────────────────────────
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env.

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | staging | production
API_VERSION=0.1.0

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://CHANGE_ME:CHANGE_ME@cluster0.xxxxx.mongodb.net/blendi-pulse

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use `openssl rand -base64 64` para gerar segredos fortes
JWT_ACCESS_SECRET=CHANGE_ME_USE_OPENSSL_RAND
JWT_REFRESH_SECRET=CHANGE_ME_USE_OPENSSL_RAND
# Usado exclusivamente para tokens temporários de redefinição de senha (10 min)
JWT_RESET_SECRET=CHANGE_ME_USE_OPENSSL_RAND

# Access token expira em 15 minutos; refresh token em 30 dias
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula
# Em produção: domínio do app (expo://..., https://...)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Passo a passo para obter as credenciais:
# 1. Acesse console.cloud.google.com
# 2. Crie (ou selecione) o projeto "blendi-pulse"
# 3. Menu lateral → APIs e Serviços → Biblioteca → ative "Google People API"
# 4. APIs e Serviços → Credenciais → Criar credenciais → ID do cliente OAuth 2.0
# 5. Tipo de aplicativo: "Aplicativo da Web"
# 6. Origens JavaScript autorizadas: http://localhost:3000
# 7. URIs de redirecionamento autorizados: http://localhost:3000/auth/google/callback
# 8. Copie o Client ID e o Client Secret gerados abaixo

GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
# Dev: http://localhost:3000/auth/google/callback
# Prod: https://api.blendipulse.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
